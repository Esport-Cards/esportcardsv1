generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  ownedCards OwnedCard[]
  teamLineups TeamLineup[]
  marketplaceListings MarketplaceListing[] @relation("Seller")
  marketplacePurchases MarketplaceListing[] @relation("Buyer")
  packOpenings PackOpening[]
  performances WeeklyPerformance[]
  stats UserStats?

  @@map("users")
}

model Player {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  role        String    // Captain, Flex, Entry, Support, AWP
  game        String    // CS2, Valorant, LoL, Dota2
  team        String
  teamCode    String    // 3-letter code e.g. NAVI
  image       String?   // player photo URL
  description String?   @db.Text
  country     String?   // country code e.g. "ua", "us"
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  cardTemplates CardTemplate[]
  performances WeeklyPerformance[]
  ownedCards   OwnedCard[]

  @@map("players")
}

model CardTemplate {
  id          String   @id @default(cuid())
  playerId    String
  rarity      String   // Common, Rare, Epic, Legendary, Unique
  season      String   // e.g. "2024-S1"
  image       String?  // card artwork URL
  design      String?  // design variant
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  player     Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  ownedCards OwnedCard[]

  @@map("card_templates")
}

model OwnedCard {
  id            String   @id @default(cuid())
  serialNumber  String   @unique // unique mint number
  rarity        String
  mintedAt      DateTime @default(now())

  cardTemplateId String
  ownerId        String

  cardTemplate CardTemplate @relation(fields: [cardTemplateId], references: [id], onDelete: Cascade)
  owner        User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  listings     MarketplaceListing[]

  @@map("owned_cards")
}

model Pack {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  price       Int      // in cents
  cardCount   Int      @default(5)
  image       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  openings PackOpening[]

  @@map("packs")
}

model PackOpening {
  id          String   @id @default(cuid())
  openedAt    DateTime @default(now())

  userId      String
  packId      String
  cardIds     String[] // array of OwnedCard ids

  user        User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  pack        Pack  @relation(fields: [packId], references: [id], onDelete: Cascade)

  @@map("pack_openings")
}

model TeamLineup {
  id          String   @id @default(cuid())
  userId      String
  name        String
  totalScore  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  slots LineupSlot[]

  @@map("team_lineups")
}

model LineupSlot {
  id          String   @id @default(cuid())
  lineupId    String
  role        String   // Captain, Flex, Entry, Support, AWP
  ownedCardId String   @unique
  position    Int      // 1-5

  lineup    TeamLineup  @relation(fields: [lineupId], references: [id], onDelete: Cascade)
  ownedCard OwnedCard   @relation(fields: [ownedCardId], references: [id], onDelete: Cascade)

  @@map("lineup_slots")
}

model WeeklyPerformance {
  id          String   @id @default(cuid())
  weekStart   DateTime
  score       Int      @default(0)
  kills       Int      @default(0)
  deaths      Int      @default(0)
  assists     Int      @default(0)
  headshots   Int      @default(0)
  rating      Float    @default(0)

  userId      String
  playerId    String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  player  Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([weekStart, userId])
  @@map("weekly_performances")
}

model MarketplaceListing {
  id          String   @id @default(cuid())
  price       Int      // in cents
  listedAt    DateTime @default(now())
  soldAt      DateTime?
  isActive    Boolean  @default(true)

  ownedCardId String
  sellerId    String
  buyerId     String?

  ownedCard OwnedCard  @relation(fields: [ownedCardId], references: [id], onDelete: Cascade)
  seller     User       @relation("Seller", fields: [sellerId], references: [id], onDelete: Cascade)
  buyer      User?      @relation("Buyer", fields: [buyerId], references: [id], onDelete: Cascade)

  @@map("marketplace_listings")
}

model UserStats {
  id              String   @id @default(cuid())
  userId          String    @unique
  totalCards      Int      @default(0)
  packsOpened     Int      @default(0)
  currentRank     Int      @default(0)
  totalScore      Int      @default(0)
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_stats")
}
